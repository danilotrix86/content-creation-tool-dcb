# Copy to .env.local and fill in your keys

# Text pipeline: gemini (default) or openai
# LLM_PROVIDER=openai

# When LLM_PROVIDER=openai, text uses Chat Completions with strong/fast models
# OPENAI_STRONG_MODEL=gpt-5.4
# OPENAI_FAST_MODEL=gpt-5.4-mini
# OPENAI_IMAGE_MODEL=gpt-image-2

# Deprecated — use OPENAI_STRONG_MODEL / OPENAI_FAST_MODEL instead
# OPENAI_LLM_MODEL=gpt-4.1

# Sampling temperature for models that support it (default 0.7). Ignored for gpt-5.x / o-series unless you force:
# OPENAI_LLM_TEMPERATURE=0.7
# OPENAI_LLM_OMIT_TEMPERATURE=1

GOOGLE_GEMINI_API=
OPENAI_API_KEY=

# Supabase (articles are saved to generated_articles after each run)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for competitor research (SerpAPI + Cloudflare scraping)
SERPAPI_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Certificate errors from antivirus/HTTPS inspection — required for Gemini fetch on some setups (NODE_TLS_REJECT_UNAUTHORIZED alone is not enough):
# DEV_TLS_INSECURE=1
